{
    "ExecuteFarsitePiece": {
        "name": "ExecuteFarsitePiece",
        "dependency": {
            "dockerfile": "Dockerfile_1",
            "requirements_file": null
        },
        "tags": [
            "Farsite"
        ],
        "style": {
            "node_label": "Main piece (run Farsite)",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:fire",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "label": "Execute FARSITE (TestFARSITE wrapper)",
        "description": "Runs FARSITE via /usr/local/bin/run_farsite.sh. Copies inputs to /work, executes, and returns a ZIP of outputs + runner log.",
        "version": "0.1.0",
        "authors": [
            "IISAS / Domino-Farsite"
        ],
        "container_resources": {
            "requests": {
                "cpu": 100,
                "memory": 128
            },
            "limits": {
                "cpu": 500,
                "memory": 512
            }
        },
        "input_schema": {
            "description": "ExecuteFarsitePiece Input Model",
            "properties": {
                "lcp_path": {
                    "description": "Path to .lcp landscape file",
                    "title": "Lcp Path",
                    "type": "string"
                },
                "inputs_path": {
                    "description": "Path to FARSITE inputs file (*.input, ASCII format)",
                    "title": "Inputs Path",
                    "type": "string"
                },
                "ignition_shp_path": {
                    "description": "Path to ignition shapefile (.shp)",
                    "title": "Ignition Shp Path",
                    "type": "string"
                },
                "barrier_shp_path": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": "0",
                    "description": "Path to barrier shapefile (.shp) or '0' for no barrier",
                    "title": "Barrier Shp Path"
                },
                "output_basename": {
                    "default": "farsite_run",
                    "description": "Base name for outputs (no extension). Outputs will be written under /work/out/<output_basename>_*",
                    "title": "Output Basename",
                    "type": "string"
                },
                "outputs_type": {
                    "default": 1,
                    "description": "0=both, 1=ASCII grid (recommended baseline), 2=FlamMap binary grid",
                    "title": "Outputs Type",
                    "type": "integer"
                }
            },
            "required": [
                "lcp_path",
                "inputs_path",
                "ignition_shp_path"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "description": "ExecuteFarsitePiece Output Model",
            "properties": {
                "outputs_zip_path": {
                    "description": "ZIP archive containing all output files under /work/out",
                    "title": "Outputs Zip Path",
                    "type": "string"
                },
                "runner_log_path": {
                    "description": "Runner log path produced by run_farsite.sh (or fallback log)",
                    "title": "Runner Log Path",
                    "type": "string"
                }
            },
            "required": [
                "outputs_zip_path",
                "runner_log_path"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/valaseklukas-svg/domino-farsite-pieces/tree/main/pieces/ExecuteFarsitePiece"
    },
    "EvaluatePerimeterPiece": {
        "name": "EvaluatePerimeterPiece",
        "dependency": {
            "dockerfile": null,
            "requirements_file": "requirements_evaluate.txt"
        },
        "tags": [
            "perimeter",
            "alert",
            "farsite",
            "api"
        ],
        "style": {
            "node_label": "Evaluate & Alert",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:bell",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Vyhodnotenie prieniku perimetra poziaru z FARSITE s ochrannym buffrom, vypocita cas do zasiahnutia a odosle alarm na Dicris API.",
        "version": "0.1.0",
        "type": "piece",
        "authors": [
            "IISAS / Domino-Farsite"
        ],
        "resources": {
            "cpu": 1,
            "memory": "2Gi",
            "disk": "5Gi"
        },
        "runtime": {
            "type": "docker",
            "image": "ghcr.io/valaseklukas-svg/domino-farsite-pieces:<verzia>-group0"
        },
        "categories": [
            "Analytics",
            "GIS"
        ],
        "input_schema": {
            "properties": {
                "outputs_zip_path": {
                    "description": "Automaticke prepojenie: ZIP archiv z ExecuteFarsitePiece.",
                    "title": "Outputs Zip Path",
                    "type": "string"
                },
                "ignition_shp_path": {
                    "description": "Automaticke prepojenie: Cesta k ignition.shp z CreateIgnitionPiece.",
                    "title": "Ignition Shp Path",
                    "type": "string"
                },
                "buffer_shp_path": {
                    "description": "MANUALNE ZADANIE: Cesta k buffer shapefile na disku (napr. /home/shared_storage/buffer.shp).",
                    "title": "Buffer Shp Path",
                    "type": "string"
                },
                "api_model_name": {
                    "default": "Model 1",
                    "description": "MANUALNE ZADANIE: Nazov modelu pre API dicris.sk.",
                    "title": "Api Model Name",
                    "type": "string"
                }
            },
            "required": [
                "outputs_zip_path",
                "ignition_shp_path",
                "buffer_shp_path"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "csv_report_path": {
                    "description": "Cesta k vygenerovanemu CSV reportu.",
                    "title": "Csv Report Path",
                    "type": "string"
                },
                "alert_status": {
                    "description": "Vysledny status odoslany na API (ok, moderate, warning, critical).",
                    "title": "Alert Status",
                    "type": "string"
                }
            },
            "required": [
                "csv_report_path",
                "alert_status"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/valaseklukas-svg/domino-farsite-pieces/tree/main/pieces/EvaluatePerimeterPiece"
    },
    "CreateIgnitionPiece": {
        "name": "CreateIgnitionPiece",
        "dependency": {
            "dockerfile": "Dockerfile_ignition",
            "requirements_file": null
        },
        "tags": [
            "shapefile",
            "gps",
            "farsite"
        ],
        "style": {
            "node_label": "Create Shapefile (GPS location)",
            "node_type": "default",
            "node_style": {
                "backgroundColor": "#ebebeb"
            },
            "useIcon": true,
            "icon_class_name": "fa-solid:location-dot",
            "iconStyle": {
                "cursor": "pointer"
            }
        },
        "description": "Vytvori fiktivny bodovy Shapefile (.shp) pre inicializaciu FARSITE.",
        "version": "0.1.0",
        "type": "piece",
        "categories": [
            "Data Preparation",
            "GIS"
        ],
        "input_schema": {
            "properties": {
                "gps_text": {
                    "default": "49.066, 18.490",
                    "description": "Vloz GPS suradnice z Google Maps (napr. 48.184, 17.073).",
                    "title": "Gps Text",
                    "type": "string"
                },
                "lcp_path": {
                    "description": "Cesta k .lcp suboru na disku pre kontrolu hranic uzemia (napr. /home/shared_storage/.../final.lcp).",
                    "title": "Lcp Path",
                    "type": "string"
                }
            },
            "required": [
                "lcp_path"
            ],
            "title": "InputModel",
            "type": "object"
        },
        "output_schema": {
            "properties": {
                "ignition_shp_path": {
                    "description": "Cesta k vygenerovanemu ignition shapefile v systeme S-JTSK",
                    "title": "Ignition Shp Path",
                    "type": "string"
                }
            },
            "required": [
                "ignition_shp_path"
            ],
            "title": "OutputModel",
            "type": "object"
        },
        "secrets_schema": null,
        "source_url": "https://github.com/valaseklukas-svg/domino-farsite-pieces/tree/main/pieces/CreateIgnitionPiece"
    }
}